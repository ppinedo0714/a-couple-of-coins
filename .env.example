# Copy this file to .env and fill in values — never commit .env

# Backend
PORT=8000
DATABASE_URL=postgres://user:password@localhost:5432/coins?sslmode=disable
JWT_SECRET=replace-with-at-least-32-char-secret

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Services
PREDICTIONS_SERVICE_URL=http://localhost:8001

# Frontend URL (used for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Frontend (Vite env vars must be prefixed with VITE_)
VITE_API_BASE_URL=http://localhost:8000
